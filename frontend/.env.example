# Google Maps JavaScript API key.
# 1. Vào https://console.cloud.google.com/ → tạo project.
# 2. APIs & Services → Enable APIs → bật "Maps JavaScript API".
# 3. Credentials → Create credentials → API key → copy.
# 4. Tạo file .env (copy từ file này) và dán key vào dòng dưới.
VITE_GOOGLE_MAPS_API_KEY=

# Planning-service (basata) — upload ranh thửa (.zip) + tile XYZ ranh thửa.
# Mặc định trỏ tới server thật; chỉ đổi khi chạy server khác/localhost.
VITE_API_URL_PLANNING_TILE=https://api-planning-basata.basao.com
